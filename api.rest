# ========================================
# PAYMENTS - ROLE-BASED ACCESS CONTROL
# ========================================
# Roles:
#   - admin: full access (create, read, update, delete)
#   - super agent: create, read, update
#   - agent: read own payments only
# ========================================


# ======================================
# 1. GET ALL PAYMENTS
# ======================================
# admin/super agent: see all payments
# agent: see only their own payments
# ======================================

# GET http://localhost:8000/api/payments HTTP/1.1
# Accept: application/json
# Authorization: Bearer 4|3gGCPfAbMBqHhbz7BVRKYhzabcp8k5r9BIPx3xC35a94062c


# ======================================
# 2. CREATE PAYMENT (STORE)
# ======================================
# Authorization: admin, super agent only
#
# Required fields:
#   - amount: decimal:2 (e.g., 150.50)
#   - currency_id: exists in currencies table
#   - saved_by: user ID who created payment
#   - payment_type: "Subscription" or "Ticket"
#   - payment_method: "Cash", "Cheque", or "Transfert"
#
# Optional fields:
#   - agent_id: user ID of agent
#   - description: string, min 10 chars
#   - stock_history_id: ID from stock_histories
#   - invoice_id: ID from invoices
# ======================================

# POST http://localhost:8000/api/payments
# Accept: application/json
# Content-Type: application/json
# Authorization: Bearer 4|3gGCPfAbMBqHhbz7BVRKYhzabcp8k5r9BIPx3xC35a94062c

# {
#     "amount": "150.50",
#     "currency_id": 1,
#     "saved_by": 1,
#     "agent_id": 2,
#     "description": "Payment for ticket purchase",
#     "payment_type": "Ticket",
#     "payment_method": "Cash"
# }


# ======================================
# 3. CREATE PAYMENT - WITH SUBSCRIPTION
# ======================================

POST http://localhost:8000/api/payments HTTP/1.1
Accept: application/json
Content-Type: application/json
Authorization: Bearer 4|3gGCPfAbMBqHhbz7BVRKYhzabcp8k5r9BIPx3xC35a94062c

{
    "amount": "280.00",
    "currency_id": 1,
    "saved_by": 1,
    "description": "Monthly subscription payment",
    "payment_type": "Subscription",
    "payment_method": "Transfert"
}


# ======================================
# 4. GET SINGLE PAYMENT
# ======================================
# Authorization: all roles (with restrictions)
# admin/super agent: can see any payment
# agent: can only see their own payments
# ======================================

# GET http://localhost:8000/api/payments/019df3cc-629e-7303-a014-fc5f86edae67
# Accept: application/json
# Authorization: Bearer 4|3gGCPfAbMBqHhbz7BVRKYhzabcp8k5r9BIPx3xC35a94062c


# ======================================
# 5. UPDATE PAYMENT
# ======================================
# Authorization: admin, super agent only
# Can update: amount, payment_method, description, etc.
# ======================================

# PATCH http://localhost:8000/api/payments/019df3cc-629e-7303-a014-fc5f86edae67
# Accept: application/json
